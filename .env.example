# Telegram Login (legacy widget + HMAC verification in app/api/auth/telegram)
#
# 1) BotFather → Bot Settings → Web Login — register EVERY origin where the widget runs.
#    Example: https://oilflowai.xyz and http://localhost:3000 (dev). Telegram only accepts
#    logins from pre-registered URLs: https://oauth.telegram.org
# 2) Same place shows Client ID / Client Secret (for OIDC). This app uses the classic flow:
#    TELEGRAM_BOT_TOKEN + NEXT_PUBLIC_TELEGRAM_BOT_USERNAME — not the OIDC client secret.
# 3) Optional: /setdomain in @BotFather for older docs; Web Login URLs are what OAuth enforces now.
#
# Archived widget reference: https://oauth.telegram.org/widgets/login
TELEGRAM_BOT_TOKEN=
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=

# Related news: public channel preview https://t.me/s/<username> (no bot admin required).
TELEGRAM_NEWS_CHANNEL_USERNAME=BRICSNews
# Min seconds between background syncs when users hit /api/news/related (default 300).
# TELEGRAM_NEWS_SYNC_INTERVAL_SEC=300
# How many t.me “prev” pages to fetch per sync (default 1, max 5).
# TELEGRAM_NEWS_PUBLIC_PAGES=1
# Max rows kept in DB for the public channel (default 5).
# TELEGRAM_NEWS_DB_MAX_ROWS=5
#
# Optional Bot API webhook — only if your bot is admin on the channel (channel_post updates).
# TELEGRAM_WEBHOOK_SECRET=
# TELEGRAM_NEWS_CHANNEL_CHAT_ID=

# Random secret for signing session cookies (min 32 chars). Example: openssl rand -hex 32
AUTH_SESSION_SECRET=

# Neon — connection string from the Neon dashboard (used to register Telegram users in Postgres)
DATABASE_URL=

# Optional: same DATABASE_URL on the VPS for scripts/solana-custody (custody worker). Never commit worker .env.

# Hourly lock yield cron — use Authorization: Bearer <CRON_SECRET> for manual runs; also set in Vercel for /api/cron/hourly-lock-yield
CRON_SECRET=
