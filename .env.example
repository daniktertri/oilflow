# ──── OilFlow Terminal — Environment Variables ────

# Neon Postgres connection string
DATABASE_URL=

# EIA API key — free registration at https://www.eia.gov/opendata/register.php
EIA_API_KEY=

# OpenAI API key — for AI market briefs and news summaries (GPT-4o-mini)
OPENAI_API_KEY=

# Telegram Login (OIDC recommended)
NEXT_PUBLIC_TELEGRAM_CLIENT_ID=
# Legacy widget fallback:
# TELEGRAM_BOT_TOKEN=
# NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=

# Telegram news channel (public scraping, no bot admin required)
TELEGRAM_NEWS_CHANNEL_USERNAME=BRICSNews
# TELEGRAM_NEWS_SYNC_INTERVAL_SEC=300
# TELEGRAM_NEWS_PUBLIC_PAGES=2
# TELEGRAM_NEWS_DB_MAX_ROWS=30

# Session signing secret (min 32 chars): openssl rand -hex 32
AUTH_SESSION_SECRET=

# Cron job authorization
CRON_SECRET=
